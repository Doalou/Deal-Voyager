# ===========================================
# Deal-Voyager - Configuration Docker
# ===========================================
# Copiez ce fichier en .env et personnalisez les valeurs :
#   cp .env.example .env
#
# Puis lancez :
#   docker compose up -d --build
# ===========================================

# --- Identifiants admin (OBLIGATOIRE) ---
# /!\ Si le mot de passe contient un $, doublez-le : Pa$$word au lieu de Pa$word
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changez_moi_avec_un_vrai_mot_de_passe

# --- Base de données PostgreSQL (OBLIGATOIRE pour le mot de passe) ---
POSTGRES_USER=dealvoyager
POSTGRES_PASSWORD=changez_moi_postgres_password
POSTGRES_DB=deal_voyager

# --- Port d'écoute public (optionnel, défaut: 3000) ---
# APP_PORT=3000

# --- Discord Bot (Optionnel) ---
# Nécessite un bot créé sur le Discord Developer Portal
DISCORD_BOT_TOKEN=votre_token_bot
DISCORD_CLIENT_ID=votre_client_id

# --- Crawlee / Playwright (Optionnel) ---
# Laissez PLAYWRIGHT_EXECUTABLE_PATH vide avec l'image Docker officielle.
PLAYWRIGHT_EXECUTABLE_PATH=
PLAYWRIGHT_ARGS=
SCRAPER_HEADLESS=true
SCRAPER_MAX_CONCURRENCY=3
SCRAPER_TIMEOUT_SECS=90
SCRAPER_MAX_RETRIES=2
# Liste d'URL de proxy séparées par des virgules (facultatif).
SCRAPER_PROXY_URLS=
