# ===========================================
# Deal-Voyager — Configuration Docker
# ===========================================
# Copiez ce fichier en .env et personnalisez les valeurs :
#   cp .env.example .env
#
# Puis lancez :
#   docker compose up -d --build
# ===========================================

# --- Identifiants admin (OBLIGATOIRE) ---
# /!\ Si le mot de passe contient un $, doublez-le : Pa$$word au lieu de Pa$word
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changez_moi_avec_un_vrai_mot_de_passe

# --- Base de données PostgreSQL (OBLIGATOIRE pour le mot de passe) ---
POSTGRES_USER=dealvoyager
POSTGRES_PASSWORD=changez_moi_postgres_password
POSTGRES_DB=deal_voyager

# --- Port d'écoute public (optionnel, défaut: 3000) ---
# APP_PORT=3000
