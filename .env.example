# ==============================================================
#                    DEAL VOYAGER - DOCKER
# ==============================================================
# Ce fichier est un modèle : ne placez pas vos vrais secrets ici.
#
# 1. Copiez-le sous le nom `.env` :
#      cp .env.example .env
# 2. Remplacez au minimum toutes les valeurs marquées OBLIGATOIRE.
# 3. Démarrez l'application :
#      docker compose up -d --build
#
# Docker Compose charge automatiquement le fichier `.env` situé
# à côté de `compose.yml`.
# ==============================================================


# --------------------------------------------------------------
# 🐘 POSTGRESQL - OBLIGATOIRE
# --------------------------------------------------------------
# Identifiants utilisés pour créer la base de données au premier
# démarrage. Choisissez un mot de passe long, aléatoire et unique.
DEAL_VOYAGER_POSTGRES_USER=dealvoyager
DEAL_VOYAGER_POSTGRES_PASSWORD=changez_moi_postgres_password
DEAL_VOYAGER_POSTGRES_DB=deal_voyager

# Facultatif : URL PostgreSQL complète utilisée en priorité par le backend.
# Elle est surtout utile si le mot de passe contient des caractères réservés
# dans une URL (#, %, ?, @, /...). Ils doivent alors être encodés.
# Exemple : le mot de passe `bonjour@2026` devient `bonjour%402026`.
# Laissez vide pour que Docker Compose construise automatiquement l'URL.
DEAL_VOYAGER_DATABASE_URL=


# --------------------------------------------------------------
# 🔐 COMPTE ADMINISTRATEUR - OBLIGATOIRE
# --------------------------------------------------------------
# Ces identifiants protègent la Control Room accessible via `/admin`.
# N'utilisez pas le même mot de passe que pour PostgreSQL.
#
# Astuce : entourez une valeur contenant un `$` avec des apostrophes :
#   DEAL_VOYAGER_ADMIN_PASSWORD='mon$mot$de$passe'
DEAL_VOYAGER_ADMIN_USERNAME=admin
DEAL_VOYAGER_ADMIN_PASSWORD=changez_moi_avec_un_vrai_mot_de_passe


# --------------------------------------------------------------
# 🌐 APPLICATION
# --------------------------------------------------------------
# Port exposé sur la machine hôte.
# L'application sera disponible sur http://localhost:3000 par défaut.
DEAL_VOYAGER_APP_PORT=3000

# Origines autorisées à appeler l'API depuis un navigateur.
# En production, remplacez localhost par votre domaine public, par exemple :
#   DEAL_VOYAGER_CORS_ORIGIN=https://deal.example.com
# Plusieurs origines peuvent être séparées par des virgules.
DEAL_VOYAGER_CORS_ORIGIN=http://localhost:3000


# --------------------------------------------------------------
# 📊 LIMITES DE RESSOURCES - OPTIONNEL
# --------------------------------------------------------------
# Valeurs maximales accordées à chaque conteneur.
# CPU : 0.5 = un demi-cœur, 1 = un cœur, 2 = deux cœurs.
# Mémoire : M = mégaoctets, G = gigaoctets.
# Les valeurs proposées conviennent à une petite installation.
DEAL_VOYAGER_DB_CPU_LIMIT=1
DEAL_VOYAGER_DB_MEM_LIMIT=512M
DEAL_VOYAGER_BACKEND_CPU_LIMIT=2
DEAL_VOYAGER_BACKEND_MEM_LIMIT=4G
DEAL_VOYAGER_FRONTEND_CPU_LIMIT=1
DEAL_VOYAGER_FRONTEND_MEM_LIMIT=512M
DEAL_VOYAGER_PROXY_CPU_LIMIT=0.5
DEAL_VOYAGER_PROXY_MEM_LIMIT=256M


# --------------------------------------------------------------
# 🤖 DISCORD - OPTIONNEL
# --------------------------------------------------------------
# Nécessaire uniquement pour le bot, les alertes et le bouton d'invitation.
# Créez une application depuis le Discord Developer Portal, puis copiez :
# - le token depuis la section « Bot » ;
# - l'identifiant depuis « General Information > Application ID ».
# Ne publiez et ne commitez jamais le token du bot.
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=


# --------------------------------------------------------------
# 🕷️ CRAWLEE / PLAYWRIGHT - AVANCÉ
# --------------------------------------------------------------
# L'image Docker contient déjà Chromium : laissez ces deux champs vides
# sauf si vous souhaitez utiliser un autre exécutable ou ajouter des arguments.
PLAYWRIGHT_EXECUTABLE_PATH=
PLAYWRIGHT_ARGS=

# `true` exécute le navigateur sans interface graphique.
SCRAPER_HEADLESS=true

# Nombre de collectes exécutées simultanément. Une valeur trop élevée
# augmente fortement la consommation de mémoire et le risque de blocage.
SCRAPER_MAX_CONCURRENCY=3

# Mémoire que Crawlee peut utiliser pour ajuster sa concurrence.
# Gardez cette valeur inférieure à DEAL_VOYAGER_BACKEND_MEM_LIMIT afin de
# laisser de la place à Node.js et Chromium (3072 Mo pour une limite de 4 Go).
SCRAPER_MEMORY_MBYTES=3072

# Durée maximale d'une requête, en secondes, puis nombre de nouvelles
# tentatives autorisées en cas d'échec.
SCRAPER_TIMEOUT_SECS=120
SCRAPER_MAX_RETRIES=3

# Liste de proxies séparés par des virgules.
# Le proxy Squid inclus dans compose.yml est utilisé par défaut.
# Pour désactiver le proxy, laissez cette variable vide.
SCRAPER_PROXY_URLS=http://proxy:3128
