// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MobilePlan {
  id          Int      @id @default(autoincrement())
  operator    String   // Nom de l'opérateur (ex: "Sosh")
  planName    String   // Nom du forfait (ex: "Le 100Go")
  price       Float    // Prix en euros par mois
  dataGb      Float    // Quantité de data en Go
  calls       String?  // Info sur les appels (ex: "illimités")
  sms         String?  // Info sur les SMS (ex: "illimités")
  network           String?  // Opérateur réseau (ex: "Orange", "SFR")
  networkGeneration String?  // Génération réseau (ex: "4G", "5G")
  dataEuGb          Float?   // Data utilisable en Europe/DOM en Go
  score             Float?   // Notre score €/Go calculé
  simPrice          Float?   // Prix de la carte SIM (si différent du défaut opérateur)
  activationPrice   Float?   // Frais d'activation / livraison
  cancellationPrice Float?   // Frais de résiliation (0 si sans engagement)
  url         String?  // Lien vers l'offre
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([operator, planName])
  @@index([score])
}

model OperatorSettings {
  operatorName      String   @id
  isFairplay        Boolean  @default(true)
  simPrice          Float?   // Prix de la carte SIM / activation pour cet opérateur
  activationPrice   Float?   // Frais d'activation supplémentaires (si existants)
  cancellationPrice Float?   // Frais de résiliation
  updatedAt         DateTime @updatedAt
}

model DiscordSubscription {
  id        Int      @id @default(autoincrement())
  guildId   String   // The Discord Server ID
  channelId String   // The Discord Channel ID to post in
  createdAt DateTime @default(now())

  @@unique([guildId, channelId])
}
